{
  "extends": "./tsconfig.json",
  "ts-node": {
    // these options are overrides used only by ts-node
    // same as the --compilerOptions flag and the TS_NODE_COMPILER_OPTIONS environment variable
    "compilerOptions": {
      "module": "commonjs",
      "isolatedModules": false
    },
    // experimentalResolver and transpileOnly bypass strict ESM/CommonJS module resolution conflicts
    // when running ts-node tests on Node >= 20, avoiding "Unknown file extension '.tsx'" and "ERR_MODULE_NOT_FOUND" errors.
    "experimentalResolver": true,
    "transpileOnly": true
  },
  "exclude": ["node_modules"],
  "include": ["**/*.test.ts"],
}
